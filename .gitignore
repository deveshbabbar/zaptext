# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# clerk configuration (can include secrets)
/.clerk/

# Brainstorm companion artifacts
.superpowers/
.claude/

# Environment overrides (just in case)
.env.local

# Generated artifacts
graphify-out/

# Storefront design-system reference files at repo root. These are the
# vanilla-React prototypes (menu-screen.jsx, desktop-app.jsx, etc.) the
# design tool dropped in — we consult them while porting markup verbatim
# into lib/storefront-ui/, but they're not Next.js routes and must not
# deploy. Production code lives in lib/storefront-ui/.
/app.jsx
/components.jsx
/desktop-app.jsx
/desktop-modals.jsx
/desktop.html
/index.html
/ios-frame.jsx
/menu-data.js
/menu-screen.jsx
/other-screens.jsx
/tweaks-panel.jsx
/uploads/
